---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
---

<Layout title="CLI Options | check_ptr_validname">
  <main>
    <Section fullWidthBorder index source="--help">
      <div class="content-wrapper">
        <h2>CLI Options</h2>
        <p>Command syntax:</p>
        <pre><code>check_ptr_validname -i &lt;ip-address&gt; [options]</code></pre>

        <h3>Required</h3>
        <ul>
          <li><code>-i</code>, <code>--ip &lt;ip&gt;</code>: target IPv4 or IPv6 address.</li>
        </ul>

        <h3>Resolver and Timing</h3>
        <ul>
          <li><code>-r</code>, <code>--resolver &lt;ip&gt;</code>: explicit DNS resolver.</li>
          <li><code>-t</code>, <code>--timeout-ms &lt;ms&gt;</code>: timeout per lookup in milliseconds (default: <code>2000</code>).</li>
        </ul>

        <h3>Behavior Flags</h3>
        <ul>
          <li><code>--warn-partial</code>: downgrade partial consistency from CRITICAL to WARNING.</li>
          <li><code>--idn-check</code>: enable additional IDN/punycode validation.</li>
        </ul>

        <h3>Output Flags</h3>
        <ul>
          <li><code>--perfdata</code>: append performance metrics to monitoring output.</li>
          <li><code>--json</code>: return JSON payload for automation.</li>
          <li><code>-h</code>, <code>--help</code>: print usage help.</li>
        </ul>

        <h3>Examples</h3>
        <pre><code># Basic
./build/linux-x86_64/check_ptr_validname -i 8.8.8.8

# Use explicit resolver and performance data
./build/linux-x86_64/check_ptr_validname -i 8.8.8.8 -r 1.1.1.1 --perfdata

# Automation-friendly JSON
./build/linux-x86_64/check_ptr_validname -i 2001:4860:4860::8888 --json
</code></pre>
      </div>
    </Section>
  </main>
</Layout>
