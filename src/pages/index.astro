---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Section from '../components/Section.astro';

const repository = import.meta.env.PUBLIC_REPO_URL ?? 'https://github.com/frankhildebrandt/check_ptr_validname';
const codeZip = import.meta.env.PUBLIC_CODE_ZIP_URL ?? `${repository}/archive/refs/heads/main.zip`;
const linuxBinary = import.meta.env.PUBLIC_BIN_URL ?? `${repository}/releases/latest/download/check_ptr_validname-linux-x86_64`;

const icingaCheckCommand = `object CheckCommand "check_ptr_validname" {
  import "plugin-check-command"

  command = [ PluginDir + "/check_ptr_validname" ]

  arguments += {
    "-i" = "$check_ptr_ip$"
    "-r" = "$check_ptr_resolver$"
    "--timeout-ms" = "$check_ptr_timeout_ms$"
    "--warn-partial" = {
      set_if = "$check_ptr_warn_partial$"
    }
    "--perfdata" = {
      set_if = "$check_ptr_perfdata$"
    }
    "--idn-check" = {
      set_if = "$check_ptr_idn_check$"
    }
  }

  vars.check_ptr_timeout_ms = 2000
  vars.check_ptr_perfdata = true
}`;

const quickTest = `make OS=linux ARCH=x86_64
./build/linux-x86_64/check_ptr_validname -i 8.8.8.8 --perfdata`;
---

<Layout title="check_ptr_validname | DNS PTR validation check">
  <Header gridBg>
    <small class="small">Monitoring-ready DNS validation</small>
    <h2 class="text-12 leading-12 lg:text-20 lg:leading-20"><span class="font-mono">check_ptr_validname</span></h2>
    <p class="subtitle w-95% lg:w-60% mx-auto mt-5">
      A compact C-based check that validates reverse DNS PTR records, hostname quality, and forward-confirm match for IPv4/IPv6.
    </p>
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a class="bg-gray-800 c-white py-3 px-5 text-sm" href={linuxBinary}>Download Linux x86_64 Binary</a>
      <a class="bg-gray-100 c-gray-900 py-3 px-5 text-sm" href={codeZip}>Download Source ZIP</a>
      <a class="bg-gray-100 c-gray-900 py-3 px-5 text-sm" href={repository}>Fork me on GitHub</a>
    </div>
  </Header>

  <main>
    <Section index source="overview.md" fullWidthBorder>
      <h2 class="title">What It Checks</h2>
      <ul class="subtitle-small mt-4">
        <li>IP parsing and address-family validation (IPv4/IPv6)</li>
        <li>PTR lookup against system resolver or explicit resolver</li>
        <li>Strict hostname validation with optional IDN/punycode checks</li>
        <li>Forward lookup and exact IP forward-confirm match</li>
        <li>Nagios/Icinga exit codes and optional perfdata/JSON output</li>
      </ul>
    </Section>

    <Section index source="quickstart.sh" fullWidthBorder>
      <h2 class="title">Quick Start</h2>
      <p class="subtitle-small">Build and run the check directly from the command line:</p>
      <pre><code>{quickTest}</code></pre>
    </Section>

    <Section index source="icinga2.conf" fullWidthBorder>
      <h2 class="title">Icinga2 Integration (Snippet)</h2>
      <p class="subtitle-small">Drop this check command into your Icinga2 command definitions:</p>
      <pre><code>{icingaCheckCommand}</code></pre>
      <p class="subtitle-small mt-6">Full integration examples for Icinga2, Nagios, and CLI usage are available in the docs section.</p>
      <div class="mt-6 flex gap-3 flex-wrap">
        <a class="bg-gray-800 c-white py-3 px-5 text-sm" href="/docs/code">Code Documentation</a>
        <a class="bg-gray-800 c-white py-3 px-5 text-sm" href="/docs/cli-options">CLI Options</a>
        <a class="bg-gray-800 c-white py-3 px-5 text-sm" href="/docs/integrations">Integrations</a>
      </div>
    </Section>
  </main>
</Layout>
