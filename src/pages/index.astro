---
const repository = import.meta.env.PUBLIC_REPO_URL ?? 'https://github.com/OWNER/REPO';
const codeZip = import.meta.env.PUBLIC_CODE_ZIP_URL ?? `${repository}/archive/refs/heads/main.zip`;
const linuxBinary =
  import.meta.env.PUBLIC_BIN_URL ?? `${repository}/releases/latest/download/check_ptr_validname-linux-x86_64`;
const icingaCheckCommand = `object CheckCommand "check_ptr_validname" {
  import "plugin-check-command"

  command = [ PluginDir + "/check_ptr_validname" ]

  arguments += {
    "-i" = "$check_ptr_ip$"
    "-r" = "$check_ptr_resolver$"
    "--timeout-ms" = "$check_ptr_timeout_ms$"
    "--warn-partial" = {
      set_if = "$check_ptr_warn_partial$"
    }
    "--perfdata" = {
      set_if = "$check_ptr_perfdata$"
    }
    "--idn-check" = {
      set_if = "$check_ptr_idn_check$"
    }
  }

  vars.check_ptr_timeout_ms = 2000
  vars.check_ptr_perfdata = true
}`;
const icingaApplyRule = `apply Service "ptr-validname-" for (ip => cfg in host.vars.ptr_checks) {
  import "generic-service"

  check_command = "check_ptr_validname"
  vars.check_ptr_ip = ip
  vars += cfg

  assign where host.vars.ptr_checks
}`;
const cliTest = `# lokal kompilieren
make OS=linux ARCH=x86_64

# Check ausfuehren
./build/linux-x86_64/check_ptr_validname -i 8.8.8.8 --perfdata

# optional mit festem Resolver
./build/linux-x86_64/check_ptr_validname -i 1.1.1.1 -r 8.8.8.8 --warn-partial`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>check_ptr_validname | DNS PTR Check</title>
    <style>
      :root {
        --bg: #f5f7fa;
        --panel: #ffffff;
        --text: #182230;
        --muted: #5f6c80;
        --accent: #0a7ea4;
        --accent-2: #0db39e;
        --border: #dbe3ee;
        --ok: #13795b;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at 20% 10%, #d7eff8 0%, transparent 45%),
          radial-gradient(circle at 90% 0%, #d8f5ef 0%, transparent 40%),
          var(--bg);
        line-height: 1.45;
      }

      .wrap {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
      }

      .hero {
        background: linear-gradient(125deg, #ffffff, #f3fbff);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 2rem;
        box-shadow: 0 14px 30px rgba(16, 36, 68, 0.08);
      }

      h1 {
        margin: 0 0 0.5rem;
        font-size: clamp(1.6rem, 3.8vw, 2.5rem);
      }

      .lead {
        margin: 0;
        color: var(--muted);
        max-width: 70ch;
      }

      .buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.25rem;
      }

      .btn {
        display: inline-block;
        text-decoration: none;
        font-weight: 600;
        border-radius: 10px;
        padding: 0.7rem 1rem;
        border: 1px solid transparent;
      }

      .btn-primary {
        background: var(--accent);
        color: #fff;
      }

      .btn-secondary {
        background: #fff;
        color: var(--text);
        border-color: var(--border);
      }

      .grid {
        display: grid;
        gap: 1rem;
        margin-top: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        justify-content: center;
        align-items: start;
      }

      @media (min-width: 860px) {
        .grid {
          grid-template-columns: repeat(2, minmax(320px, 1fr));
        }
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem;
        width: 100%;
        max-width: 480px;
        margin-inline: auto;
      }

      h2 {
        margin-top: 0.2rem;
        margin-bottom: 0.5rem;
        font-size: 1.1rem;
      }

      p,
      li {
        color: var(--muted);
      }

      code,
      pre {
        font-family: "IBM Plex Mono", "SFMono-Regular", Menlo, monospace;
      }

      pre {
        margin: 0.6rem 0 0;
        border-radius: 10px;
        background: #0f1722;
        color: #e8f1ff;
        padding: 0.85rem;
        overflow: auto;
        font-size: 0.85rem;
      }

      .status {
        color: var(--ok);
        font-weight: 600;
      }

      .fork {
        position: fixed;
        top: 22px;
        right: -46px;
        width: 240px;
        text-align: center;
        transform: rotate(45deg);
        background: var(--accent-2);
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        padding: 0.45rem 1rem;
        box-shadow: 0 8px 18px rgba(10, 80, 96, 0.25);
        z-index: 10;
      }

      @media (max-width: 700px) {
        .fork {
          top: 10px;
          right: 10px;
          width: auto;
          padding: 0.5rem 0.8rem;
          border-radius: 999px;
          transform: none;
        }
      }
    </style>
  </head>
  <body>
    <a class="fork" href={repository} target="_blank" rel="noreferrer">Fork me on GitHub</a>

    <main class="wrap">
      <section class="hero">
        <h1>check_ptr_validname</h1>
        <p class="lead">
          Kompakter DNS-Monitoring-Check: PTR aufloesen, Hostname validieren, Forward-Confirm-Match pruefen. Ergebnis ist Nagios/Icinga-kompatibel mit Exit-Codes 0-3.
        </p>

        <div class="buttons">
          <a class="btn btn-primary" href={linuxBinary}>Linux Binary herunterladen</a>
          <a class="btn btn-secondary" href={codeZip}>Quellcode als ZIP</a>
          <a class="btn btn-secondary" href={repository}>Repository</a>
        </div>
      </section>

      <section class="grid">
        <article class="card">
          <h2>ICINGA CheckCommand</h2>
          <p>Beispiel fuer <code>/etc/icinga2/conf.d/commands.conf</code>:</p>
          <pre><code>{icingaCheckCommand}</code></pre>
        </article>

        <article class="card">
          <h2>APPLY RULE fuer Services</h2>
          <p>Beispiel fuer mehrere IPs je Host via <code>host.vars.ptr_checks</code>:</p>
          <pre><code>{icingaApplyRule}</code></pre>
        </article>

        <article class="card">
          <h2>CLI-Test</h2>
          <p>Schneller manueller Test auf der Shell:</p>
          <pre><code>{cliTest}</code></pre>
        </article>

        <article class="card">
          <h2>Build und Release</h2>
          <p>
            <span class="status">Aktiviert via GitHub Actions</span><br />
            1) <strong>Deploy GitHub Pages</strong>: baut diese Seite bei Push auf <code>main</code>.<br />
            2) <strong>Build Linux x86_64 Binary</strong>: erzeugt Artefakte immer, erstellt Release-Assets bei Tags wie <code>v1.0.0</code>.
          </p>
        </article>
      </section>
    </main>
  </body>
</html>
